# Human Between — root .env.example
#
# This file documents the FULL set of env vars used across HB apps. Each app
# under apps/* has its own .env.example with only the subset it needs.
#
# Copy this to .env (gitignored), then provision each resource per
# docs/secrets-checklist.md. None of these values should be shared with GN
# Motion — every credential is a NEW resource under the Human Between
# identity.

# --- Anthropic ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI (Whisper transcription only — optional) ---
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# --- Notion (HB workspace, NOT GN's) ---
NOTION_API_KEY=
NOTION_DB_CONTACTS_ID=
NOTION_DB_COMPANIES_ID=
NOTION_DB_OPS_ID=

# --- Telegram (HB bots, NEW from BotFather, never reuse GN tokens) ---
TELEGRAM_BOT_TOKEN_CHIEF=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=

# --- Google Workspace HB ---
GMAIL_USER_EMAIL=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Drive (HB Shared Drive, distinct from GN MOTION drive) ---
HB_DRIVE_ID=
HB_DRIVE_ROOT_FOLDER_ID=

# --- Slack (HB workspace, if used) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_OPS_CHANNEL_ID=

# --- Vercel (HB team) ---
VERCEL_TOKEN=

# --- Resend (HB domain) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Runtime ---
HB_TZ=Europe/Paris
HB_LOG_LEVEL=INFO
