# Human Between — Hermes Agent .env
#
# Every value here is a NEW Human Between resource. Never reuse a GN Motion
# credential — see ~/Projects/human-between/docs/secrets-checklist.md.
#
# Hermes Agent reads this when HERMES_HOME points at this directory.

# --- Anthropic (HB workspace / key) ---
ANTHROPIC_API_KEY=

# --- OpenAI (HB org / key — for Whisper STT + optional model provider) ---
OPENAI_API_KEY=

# --- Codex (default provider per config.yaml — adjust if you use a different LLM) ---
OPENAI_CODEX_API_KEY=

# --- Telegram (HB bot from BotFather, distinct from GN bots) ---
TELEGRAM_BOT_TOKEN=

# --- Notion (HB workspace, NOT GN's Prospect Pipeline) ---
NOTION_API_KEY=

# --- Google Workspace HB (Gmail / Drive / Calendar — optional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Slack (HB workspace, optional) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Discord (HB server, optional) ---
DISCORD_BOT_TOKEN=

# --- Other model providers (optional fallbacks) ---
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# --- Runtime ---
HB_TZ=Europe/Paris
