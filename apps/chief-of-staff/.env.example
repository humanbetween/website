# Chief of Staff — HB Telegram bot
#
# Every value here is a NEW Human Between resource. Never reuse a GN Motion
# credential — see ~/Projects/human-between/docs/secrets-checklist.md

# --- Anthropic (HB workspace / key) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Telegram (new bot from BotFather, distinct from GN bots) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Notion (HB workspace, NOT GN's Prospect Pipeline) ---
# Optional at this scaffold stage — bot starts with /ping if these are empty.
NOTION_API_KEY=
NOTION_DB_CONTACTS_ID=

# --- OpenAI (Whisper, optional) ---
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# --- Runtime ---
CHIEF_TZ=Europe/Paris
CHIEF_LOG_LEVEL=INFO
CHIEF_EOD_REMINDER_HOUR=21
